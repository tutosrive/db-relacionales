dos, especialidad, teléfono, correo)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br&gt;PlanSalud (&lt;u&gt;idPlanSalud Pk,&lt;/u&gt;&amp;nbsp;precio, tipo)&lt;br&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;Paciente (&lt;u&gt;idPaciente PK&lt;/u&gt;,&amp;nbsp; idEps FK, idPlanSalud FK, nombre, apellidos, edad, género, teléfono, dirección, correo)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Cita (&lt;u&gt;idCita PK&lt;/u&gt;, idMédico FK, idPaciente FK, fecha, hora, motivo)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;HistoriaClínica (&lt;u&gt;idHistoriaClinica PK&lt;/u&gt;,&amp;nbsp;&lt;u&gt;idPaciente FK&lt;/u&gt;,&amp;nbsp;fecha_creacion)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;Diagnóstico (&lt;u&gt;idDiagnóstico PK&lt;/u&gt;, idHistoriaClinica FK, idCita FK, descripción, tratamiento)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;Medicamento(&lt;u&gt;idMedicamento PK&lt;/u&gt;, nombre, cantidad_mg, viaAdministración)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br&gt;Servicio(&lt;u&gt;idServicios PK&lt;/u&gt;, nombre, descripcion)&lt;br&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;DiagnósticoxMedicamento(&lt;u&gt;idDiagnóstico FK&lt;/u&gt;, &lt;u&gt;idMedicamento FK&lt;/u&gt;, &lt;u&gt;fecha&lt;/u&gt;, cantidad)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;DiagnósticoxServicios(&lt;u&gt;idDiagnóstico FK&lt;/u&gt;,&lt;u&gt; idServicios FK&lt;/u&gt;, &lt;u&gt;fecha&lt;/u&gt;, descripción)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;Vehículo (&lt;u&gt;placaVehiculo PK&lt;/u&gt;, equipamiento)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;Auxiliar (&lt;u&gt;idAuxiliar PK&lt;/u&gt;, nombre, apellidos, teléfono, correo)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br&gt;VisitaDomiciliaria (&lt;u&gt;idVisita PK&lt;/u&gt;, idPaciente FK, placaVehiculo FK, idAuxiliar FK, motivo, fecha, reporte)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;Turno (&lt;u&gt;idTurno PK&lt;/u&gt;, horaInicio, horaFin)&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;&lt;br style=&quot;padding: 0px; margin: 0px;&quot;&gt;MedicoxTurno (&lt;u&gt;idMedico FK&lt;/u&gt;, &lt;u&gt;idTurno FK&lt;/u&gt;, &lt;u&gt;fecha )&lt;/u&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
