erDiagram
    Profesional {
        string codigo PK
        string nombre_artistico
        string nombre_real
        string especialidad_principal
        string anos_trayectoria
        string sociedad_gestion
        float tarifa_base
        string disponibilidad
        string pais_residencia
    }

    Produccion {
        string codigo_produccion PK
        string titulo
        string genero_principal
        string tipo
        float presupuesto
        date fecha_inicio_preproduccion
        date fecha_estimada_lanzamiento
        string sello_discografico
        string estado
    }

    Cancion {
        string ISRC PK
        string titulo
        int duracion_segundos
        string letra
        date fecha_registro_derechos
        string idioma
        string codigo_produccion FK
    }

    Version {
        int numero_version
        string tipo_version
        string ruta_archivo
        datetime fecha_hora_creacion
        string ingeniero_responsable
        string notas_tecnicas
        string estado
        string ISRC FK
    }

    Participacion {
        string codigo_profesional FK
        string ISRC FK
        string rol_especifico
        float porcentaje_regalias
        date fecha_firma_acuerdo
        string tipo_contrato
        string estado_acuerdo
    }

    ReferenciaCancion {
        string ISRC_origen FK
        string ISRC_destino FK
        string tipo_referencia
        float porcentaje_utilizado
        boolean autorizacion_legal
        date fecha_autorizacion
        string condiciones_licencia
        float porcentaje_regalias_transferir
    }

    Estudio {
        string codigo_estudio PK
        string nombre_comercial
        string direccion
        string ciudad
        string pais
        int ano_fundacion
        string certificaciones
        float valoracion_promedio
    }

    Sala {
        string codigo_sala PK
        string nombre_o_numero
        string tipo
        int capacidad_maxima
        string equipamiento_especifico
        string tratamiento_acustico
        float tarifa_hora
        float tarifa_dia
        string disponibilidad
        string codigo_estudio FK
    }

    Sesion {
        string codigo_sesion PK
        datetime fecha_hora_inicio
        datetime fecha_hora_fin
        string objetivo
        float costo_total
        string notas_tecnicas
        string estado
        string codigo_produccion FK
        string codigo_sala FK
    }

    AsistenciaSesion {
        string codigo_sesion FK
        string codigo_profesional FK
        string rol
        float horas_trabajadas
        float tarifa_aplicada
        string observaciones
    }

    Contrato {
        string codigo_contrato PK
        date fecha_firma
        date fecha_vencimiento
        int numero_albumes
        float monto_anticipo
        float porcentaje_regalias_sello
        string clausula_exclusividad
        string territorios
        string estado
        string condiciones_especiales
        string codigo_profesional FK
        string codigo_sello FK
    }

    Sello {
        string codigo_sello PK
        string nombre
        string pais
    }

    Plataforma {
        string codigo_plataforma PK
        string nombre
        string tipo
        string modelo_negocio
        float tarifa_promedio_reproduccion
        string alcance
        int audiencia_potencial
    }

    Distribucion {
        string codigo_produccion FK
        string codigo_plataforma FK
        date fecha_publicacion
        string territorios_autorizados
        string estado
        date fecha_remocion
        string razon_remocion
    }

    ReporteRegalias {
        string periodo
        string codigo_plataforma FK
        string ISRC FK
        int reproducciones_completas
        int reproducciones_parciales
        float ingresos_brutos
        float comision
        float ingresos_netos
        string pais_origen
        date fecha_recepcion
        string estado_reporte
    }

    Equipamiento {
        string codigo_inventario PK
        string nombre
        string categoria
        string marca_modelo
        string numero_serie
        int ano_adquisicion
        float valor_compra
        float valor_reposicion
        string estado_actual
        string ubicacion
        string codigo_estudio FK
    }

    AsignacionEquipamiento {
        string codigo_sesion FK
        string codigo_equipamiento FK
        string profesional_responsable FK
        datetime fecha_hora_salida
        datetime fecha_hora_retorno_programada
        datetime fecha_hora_retorno_real
        string estado_retorno
        string descripcion_danos
        float costo_reparacion
        string responsable_dano
    }

    %% Relaciones
    Produccion ||--o{ Cancion : contiene
    Cancion ||--o{ Version : tiene
    Profesional }o--o{ Cancion : participa_en "via Participacion"
    Cancion }o--o{ Cancion : referencia "via ReferenciaCancion"
    Estudio ||--o{ Sala : tiene
    Produccion ||--o{ Sesion : asocia
    Sala ||--o{ Sesion : reserva
    Sesion }o--o{ Profesional : asiste "via AsistenciaSesion"
    Profesional }o--o{ Sello : firma "via Contrato"
    Sello ||--o{ Contrato : involucra
    Profesional ||--o{ Contrato : tiene
    Produccion }o--o{ Plataforma : distribuida_en "via Distribucion"
    Plataforma ||--o{ ReporteRegalias : genera
    Cancion ||--o{ ReporteRegalias : recibe
    Estudio ||--o{ Equipamiento : posee
    Sesion }o--o{ Equipamiento : utiliza "via AsignacionEquipamiento"
    Profesional ||--o{ AsignacionEquipamiento : responsable